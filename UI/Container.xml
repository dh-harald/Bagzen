<?xml version="1.0"?>
<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/FrameXML\UI.xsd">

  <Script file="Container.lua"/>

  <Button name="BagzenContainerFrameItemButtonTemplate" inherits="ContainerFrameItemButtonTemplate" hidden="true" virtual="true">
    <NormalTexture name="$parentNormalTexture" file="Interface\AddOns\Bagzen\textures\UI-Quickslot2.tga">
      <Size>
        <AbsDimension x="64" y="64"/>
      </Size>
      <Anchors>
        <Anchor point="CENTER">
          <Offset x="0" y="-1"/>
        </Anchor>
      </Anchors>
    </NormalTexture>
    <PushedTexture file="Interface\AddOns\Bagzen\textures\UI-Quickslot-Depress.tga"/>
    <HighlightTexture file="Interface\AddOns\Bagzen\textures\ButtonHilight-Square.tga" alphaMode="ADD"/>
  </Button>

  <Frame name="BagzenContainerTemplate" virtual="true">
    <Layers>
      <Layer level="BACKGROUND">
        <Texture name="$parentBackground" setAllPoints="true">
          <Color r="0.05" g="0.05" b="0.05" a="0.9"/>
        </Texture>
      </Layer>
    </Layers>
    <BackdropInsets>
      <AbsInset left="1" right="1" top="1" bottom="1"/>
    </BackdropInsets>
    <Frames>
      <Frame name="$parentContainerFrame">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="TOPLEFT">
            <Offset>
              <AbsDimension x="2" y="-32"/>
            </Offset>
          </Anchor>
        </Anchors>
      </Frame>
    </Frames>
  </Frame>
</Ui>
